{
  "manifest_version": 3,
  "name": "PageMind",
  "description": "Summarize any page and ask questions using AI",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PageMind"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"]
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}
